# === Required ===

# Powers the agent's conversational model (Claude)
ANTHROPIC_API_KEY=

# Random string to secure gateway API access
# On Railway, use ${{secret(32)}} template function to auto-generate
OPENCLAW_GATEWAY_TOKEN=

# === Telegram Channel ===

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to message the bot
# Find your ID: message @userinfobot on Telegram
TELEGRAM_ALLOW_FROM=

# DM access policy: "allowlist" (default) or "open"
# TELEGRAM_DM_POLICY=allowlist

# === Optional ===

# Default agent model
# OPENCLAW_MODEL=anthropic/claude-sonnet-4-6

# Alternative LLM provider for GPT models (fallback if no Anthropic key)
# OPENAI_API_KEY=

# Enables the web_search tool for live web results
# BRAVE_API_KEY=

# Enable gateway Control UI (true/false)
# CONTROL_UI_ENABLED=true
